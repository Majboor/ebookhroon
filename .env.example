# ─── Folio environment ───────────────────────────────────────────────────────

# Public app URL (used for metadata and OpenGraph tags)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# URL of the FastAPI backend (backend/main.py). The Next.js app talks to this
# for all books/pages/blocks/auth data. Required — the app throws without it.
FASTAPI_BASE_URL="http://127.0.0.1:8002"
NEXT_PUBLIC_FASTAPI_BASE_URL="http://127.0.0.1:8002"

# Optional: where uploaded images are publicly served from. Defaults to the
# FastAPI base URL above (it serves /uploads/*). Only set this if you host
# uploads somewhere else (e.g. a CDN or object storage).
# NEXT_PUBLIC_UPLOAD_PUBLIC_BASE_URL="http://127.0.0.1:8002"

# ─── Storage ─────────────────────────────────────────────────────────────────
# No database or auth service required — all data lives in /data/*.csv and
# uploaded images are saved to /public/uploads/. Passwords are stored as
# salted PBKDF2-SHA256 hashes.
